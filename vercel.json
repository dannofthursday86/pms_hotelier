{
  "version": 2,
  "builds": [
    {
      "src": "pages/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/(.*).html",
      "dest": "/$1.html"
    }
  ]
}